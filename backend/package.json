{
  "name": "house-of-valerion-backend",
  "version": "1.0.0",
  "description": "Backend API for House of Valerion ecommerce store",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma": "prisma",
