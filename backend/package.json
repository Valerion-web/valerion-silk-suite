  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^7.8.0"
  }
}
